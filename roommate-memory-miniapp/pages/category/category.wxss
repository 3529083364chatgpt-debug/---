/* pages/category/category.wxss */

.page-category {
  padding-bottom: 120rpx;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  background: white;
  border-bottom: 1rpx solid var(--rule);
  padding: 20rpx 30rpx;
  gap: 16rpx;
}

.tab-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  border: 1rpx solid var(--rule);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--muted);
  background: white;
}

.tab-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

/* 筛选选项 */
.filter-options {
  background: white;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid var(--rule);
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted);
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.filter-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-btn {
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--rule);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--muted);
  background: white;
}

.filter-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

/* 筛选切换 */
.filter-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: var(--bg);
  font-size: 24rpx;
  color: var(--muted);
}

.toggle-icon {
  font-size: 20rpx;
}

/* 回忆列表 */
.memory-list {
  padding: 20rpx 30rpx;
}

.memory-card {
  background: white;
  border-radius: var(--radius);
  border: 1rpx solid var(--rule);
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: var(--transition);
}

.memory-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx var(--shadow);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--rule);
}

.card-type {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-type.photo {
  background: rgba(232, 155, 108, 0.1);
  color: var(--accent);
}

.card-type.chat {
  background: rgba(123, 166, 156, 0.1);
  color: var(--accent2);
}

.card-type.story {
  background: rgba(138, 126, 109, 0.1);
  color: var(--muted);
}

.card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
}

.card-time {
  font-size: 22rpx;
  color: var(--muted);
}

.card-body {
  padding: 24rpx;
}

.card-preview {
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.card-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid var(--rule);
  background: var(--bg);
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--muted);
  line-height: 1.6;
}