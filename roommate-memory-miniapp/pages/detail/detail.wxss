/* pages/detail/detail.wxss */

.page-detail {
  padding-bottom: 40rpx;
}

/* 回忆详情 */
.memory-detail {
  background: white;
  margin: 20rpx;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx var(--shadow);
}

.detail-header {
  padding: 30rpx;
  border-bottom: 1rpx solid var(--rule);
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 16rpx;
}

.detail-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.detail-time {
  font-size: 26rpx;
  color: var(--muted);
}

.detail-author {
  font-size: 26rpx;
  color: var(--muted);
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 图片详情 */
.detail-images {
  padding: 20rpx;
}

.detail-images image {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

/* 聊天详情 */
.detail-chat {
  padding: 30rpx;
  background: var(--bg);
}

.chat-msg {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.chat-msg:last-child {
  margin-bottom: 0;
}

.chat-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--accent);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.chat-content {
  flex: 1;
}

.chat-name {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}

.chat-bubble {
  background: white;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  display: inline-block;
  max-width: 80%;
}

/* 文字详情 */
.detail-text {
  padding: 30rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--ink);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: white;
  border: 1rpx solid var(--rule);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
}

.action-btn.delete {
  color: #e74c3c;
  border-color: #e74c3c;
}

.action-btn.share {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}

/* 留言区 */
.comments-section {
  margin: 20rpx;
  background: white;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx var(--shadow);
}

.section-header {
  padding: 30rpx;
  border-bottom: 1rpx solid var(--rule);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
}

.comments-list {
  max-height: 600rpx;
  overflow-y: auto;
  padding: 20rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--accent2);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
}

.comment-time {
  font-size: 22rpx;
  color: var(--muted);
}

.comment-text {
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.5;
}

.empty-comments {
  text-align: center;
  padding: 40rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.comment-input {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  border-top: 1rpx solid var(--rule);
}

.comment-input input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: var(--bg);
  border-radius: 40rpx;
  font-size: 28rpx;
}

.comment-input .btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
}