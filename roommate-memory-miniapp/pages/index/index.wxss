/* pages/index/index.wxss */

.page-index {
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid var(--rule);
}

.search-input {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink);
}

/* 那年今日 */
.on-this-day {
  background: linear-gradient(135deg, rgba(232, 155, 108, 0.05), rgba(123, 166, 156, 0.05));
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
}

.on-this-day-scroll {
  white-space: nowrap;
}

.on-this-day-card {
  display: inline-block;
  width: 300rpx;
  background: white;
  border-radius: var(--radius);
  padding: 24rpx;
  margin-right: 20rpx;
  border: 1rpx solid var(--rule);
  vertical-align: top;
}

.card-year {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 12rpx;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-preview {
  font-size: 24rpx;
  color: var(--muted);
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 时间线 */
.timeline {
  padding: 0 30rpx;
}

.timeline-group {
  margin-bottom: 40rpx;
}

.timeline-date {
  display: inline-block;
  background: var(--accent);
  color: white;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  margin-left: 40rpx;
  position: relative;
}

.timeline-date::before {
  content: '';
  position: absolute;
  left: -20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  background: var(--accent);
  border-radius: 50%;
  border: 4rpx solid var(--bg);
}

.memory-cards {
  padding-left: 40rpx;
}

/* 记忆卡片 */
.memory-card {
  background: white;
  border-radius: var(--radius);
  border: 1rpx solid var(--rule);
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: var(--transition);
}

.memory-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx var(--shadow);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--rule);
}

.card-type {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-type.photo {
  background: rgba(232, 155, 108, 0.1);
  color: var(--accent);
}

.card-type.chat {
  background: rgba(123, 166, 156, 0.1);
  color: var(--accent2);
}

.card-type.story {
  background: rgba(138, 126, 109, 0.1);
  color: var(--muted);
}

.card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
}

.card-time {
  font-size: 22rpx;
  color: var(--muted);
}

.card-body {
  padding: 24rpx;
}

.card-preview {
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.card-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
}

.card-chat-preview {
  background: var(--bg);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.chat-msg {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.chat-msg:last-child {
  margin-bottom: 0;
}

.chat-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--accent);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.chat-content {
  flex: 1;
}

.chat-name {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 6rpx;
}

.chat-bubble {
  background: white;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
  display: inline-block;
  max-width: 80%;
}

.more-messages {
  font-size: 22rpx;
  color: var(--muted);
  text-align: center;
  margin-top: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid var(--rule);
  background: var(--bg);
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.card-stats {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--muted);
  line-height: 1.6;
}